{
  "name": "vidacure-server",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/server.ts",
    "scheduler:dev": "nodemon --watch 'src/**/*.ts' --exec 'ts-node' src/jobs/scheduler.ts",
    "scheduler:start": "node dist/jobs/scheduler.js",
    "drip:once": "ts-node src/jobs/run-once.ts drip",
    "drip:seed": "ts-node src/jobs/seed-drip-test.ts",
    "backup:once": "ts-node src/jobs/run-once.ts backup",
    "archive:once": "ts-node src/jobs/run-once.ts archive",
    "lint": "eslint 'src/**/*.ts'",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "create-admin": "ts-node scripts/create-admin.ts",
    "pm2:dev": "pm2 start ecosystem.config.js",
    "pm2:prod": "npm run build && pm2 startOrReload ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:logs:scheduler": "pm2 logs vidacure-scheduler",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch --forceExit --detectOpenHandles"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbdulWaheed73/vidacure-server.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AbdulWaheed73/vidacure-server/issues"
  },
  "homepage": "https://github.com/AbdulWaheed73/vidacure-server#readme",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^24.3.0",
    "@types/node-cron": "^3.0.11",
    "@types/node-fetch": "^2.6.13",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "dotenv": "^17.2.1",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^5.5.4",
    "express": "^5.1.0",
    "install": "^0.13.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.10",
    "npm": "^11.5.2",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@criipto/oidc": "^1.0.0",
    "@criipto/verify-express": "^1.0.4",
    "@sentry/node": "^10.61.0",
    "@types/stripe": "^8.0.416",
    "argon2": "^0.44.0",
    "axios": "^1.12.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^3.2.0",
    "mongoose": "^8.17.1",
    "node-cron": "^3.0.3",
    "otplib": "^13.3.0",
    "qrcode": "^1.5.4",
    "resend": "^6.9.3",
    "stripe": "^18.5.0",
    "uuid": "^13.0.0"
  }
}
